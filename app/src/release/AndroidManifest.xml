<?xml version="1.0" encoding="utf-8"?>
<!--
  Release-variant manifest overlay.
  Strips debug-only exported receivers per THREAT_MODEL.md § 4.1.
  These receivers exist for internal tooling (live-reload of plugins,
  Compose-DSL UI tree dumps, etc.) and have no place in shipped builds.
  Manifest merger applies tools:node="remove" at the receiver name match.
  The nightly variant inherits this via matchingFallbacks=[release] in
  app/build.gradle.kts.

  ScriptExecutionReceiver is also stripped: it accepts arbitrary JS for
  in-process QuickJS execution, which is a remote code execution surface
  no shipped build should expose. Even with a signature permission this
  receiver is unsafe to ship — see THREAT_MODEL § 4.1.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <receiver
            android:name=".core.tools.packTool.ToolPkgDebugInstallReceiver"
            tools:node="remove" />

        <receiver
            android:name=".core.tools.packTool.PackageDebugRefreshReceiver"
            tools:node="remove" />

        <receiver
            android:name=".core.tools.packTool.ToolPkgComposeDslDebugDumpReceiver"
            tools:node="remove" />

        <receiver
            android:name=".core.tools.javascript.ScriptExecutionReceiver"
            tools:node="remove" />
    </application>

</manifest>
